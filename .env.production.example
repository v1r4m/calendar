# ── 프로덕션(EC2) .env 예시 ──
# cp .env.production.example .env  후 값 채우기

# 공통
WEEK_START=sunday
TIMEZONE=Asia/Seoul

# ── 공용 프록시 연동 (compose가 사용) ──────────────────
# eta-caddy 가 붙어있는 Docker 네트워크 이름.
# 확인:  docker inspect eta-caddy-1 --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}'
PROXY_NETWORK=eta_default

# ── Google Calendar ──────────────────────────────────
# credentials.json / token.json 은 로컬에서 만든 걸 서버로 복사 (바인드마운트됨)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_IDS=

# ── Notion ───────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_IDS=
NOTION_DATE_PROPERTY=

# ── 관리자 모드 ──────────────────────────────────────
ADMIN_EMAILS=choyoung7789@gmail.com
# 긴 랜덤값 (python -c "import secrets;print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-long-random-string
DEFAULT_NOTION_CATEGORY=private
BUSY_LABEL=다른 사람의 일정
PRIVATE_LABEL=비공개 일정

# 프로덕션 관리자 Google 로그인을 쓰려면 credentials.json 을 Web OAuth 클라이언트로
# 발급받아 두면 된다 (redirect: https://calendar.viram.dev/auth/callback). DEPLOY.md §5.
# 공개 뷰어만 띄울 거면 ADMIN_EMAILS 만 있어도 사이트는 정상 동작.
