# ── 공통 ──────────────────────────────────────────────
# 주 시작 요일: sunday | monday  (Notion Calendar 기본은 sunday)
WEEK_START=sunday
# 표시 시간대 (IANA tz)
TIMEZONE=Asia/Seoul
# Flask 개발 서버 포트
PORT=5000

# ── 관리자 모드 ──────────────────────────────────────
# Google 로그인 이메일이 아래 목록에 있으면 관리자(숨김 토글 가능). 콤마 구분.
ADMIN_EMAILS=
# 세션 서명 키. 아무 긴 랜덤 문자열로 바꾸세요 (python -c "import secrets;print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-long-random-string
# 아직 분류 안 한 Notion 일정의 기본 카테고리: private | busy | public
DEFAULT_NOTION_CATEGORY=private
# 외부에 마스킹되어 표시될 문구
BUSY_LABEL=다른 사람의 일정
PRIVATE_LABEL=비공개 일정

# ── Google Calendar ──────────────────────────────────
# Google Cloud Console에서 받은 OAuth 클라이언트(데스크톱 앱) 파일 경로.
# 받은 파일을 프로젝트 루트에 credentials.json 으로 두면 그대로 두면 됩니다.
GOOGLE_CREDENTIALS_FILE=credentials.json
# 최초 로그인 후 자동 생성됨 (지우면 다시 로그인)
GOOGLE_TOKEN_FILE=token.json
# 비우면 연결된 모든 캘린더를 가져옵니다. 특정 캘린더만 원하면 콤마로 ID 나열.
GOOGLE_CALENDAR_IDS=

# ── Notion ───────────────────────────────────────────
# notion.so/my-integrations 에서 만든 내부 통합 토큰 (secret_...)
NOTION_TOKEN=
# 일정으로 표시할 데이터베이스 ID (여러 개면 콤마로 구분)
NOTION_DATABASE_IDS=
# 날짜로 쓸 속성 이름. 비우면 첫 번째 date 타입 속성을 자동 사용.
NOTION_DATE_PROPERTY=
